<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_gradient" android:fillViewport="true" android:overScrollMode="never">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="40dp" android:layout_marginBottom="24dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="‹" android:textSize="22sp" android:textColor="@color/white"
                android:padding="0dp" android:layout_marginEnd="16dp"
                app:strokeColor="@color/card_stroke" app:strokeWidth="1dp"
                app:cornerRadius="14dp" app:backgroundTint="@color/card_bg"/>
            <TextView android:id="@+id/tv_screen_title"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Новый тариф" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- Fields card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="22dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <!-- Название -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="НАЗВАНИЕ ТАРИФА" android:textSize="10sp" android:letterSpacing="0.1"
                    android:textColor="#55FFFFFF" android:layout_marginBottom="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/input_bg" android:paddingHorizontal="16dp" android:paddingVertical="4dp"
                    android:layout_marginBottom="20dp">
                    <EditText android:id="@+id/et_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Например: Ночной, Город, Загород…"
                        android:hintTextColor="#40FFFFFF" android:textColor="@color/white"
                        android:textSize="16sp" android:background="@null" android:inputType="text"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#10FFFFFF" android:layout_marginBottom="18dp"/>

                <!-- Цена за км -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Цена за километр" android:textSize="14sp" android:textColor="#DDFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₽ за 1 км" android:textSize="11sp" android:textColor="#44FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/input_bg" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                        <EditText android:id="@+id/et_price_km"
                            android:layout_width="70dp" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:textColor="@color/white"
                            android:textSize="16sp" android:textStyle="bold"
                            android:background="@null" android:gravity="end" android:maxLength="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" ₽" android:textSize="13sp" android:textColor="#66FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Минималка -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Минимальная стоимость" android:textSize="14sp" android:textColor="#DDFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Цена при СТАРТ → сразу СТОП" android:textSize="11sp" android:textColor="#44FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/input_bg" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                        <EditText android:id="@+id/et_min_price"
                            android:layout_width="70dp" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:textColor="@color/white"
                            android:textSize="16sp" android:textStyle="bold"
                            android:background="@null" android:gravity="end" android:maxLength="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" ₽" android:textSize="13sp" android:textColor="#66FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Расход -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Расход топлива" android:textSize="14sp" android:textColor="#DDFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Литров на 100 км" android:textSize="11sp" android:textColor="#44FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/input_bg" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                        <EditText android:id="@+id/et_fuel"
                            android:layout_width="70dp" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:textColor="@color/white"
                            android:textSize="16sp" android:textStyle="bold"
                            android:background="@null" android:gravity="end" android:maxLength="5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" л/100" android:textSize="13sp" android:textColor="#66FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Округление -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Округление цены" android:textSize="14sp" android:textColor="#DDFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="10 = до десятков (127→130)" android:textSize="11sp" android:textColor="#44FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/input_bg" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                        <EditText android:id="@+id/et_rounding"
                            android:layout_width="70dp" android:layout_height="wrap_content"
                            android:inputType="number" android:textColor="@color/white"
                            android:textSize="16sp" android:textStyle="bold"
                            android:background="@null" android:gravity="end" android:maxLength="5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" ₽" android:textSize="13sp" android:textColor="#66FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="✓  Сохранить тариф" android:textSize="16sp" android:textColor="@color/white"
            app:backgroundTint="@color/accent_blue" app:cornerRadius="18dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="🗑  Удалить тариф" android:textSize="15sp" android:textColor="@color/accent_red"
            app:strokeColor="@color/accent_red" app:strokeWidth="1dp"
            app:cornerRadius="18dp" app:backgroundTint="@android:color/transparent"
            android:visibility="gone" android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
