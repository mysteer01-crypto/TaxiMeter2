<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ══ HOME ══════════════════════════════════════════════════════════════ -->
    <ScrollView android:id="@+id/screen_home"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:overScrollMode="never" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="36dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="20dp" android:paddingTop="52dp" android:paddingBottom="6dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TaxiMeter" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/white" android:letterSpacing="-0.02"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Выберите тариф" android:textSize="13sp" android:textColor="#77FFFFFF"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:text="⚙" android:textSize="18sp" android:textColor="@color/white"
                    android:padding="0dp"
                    app:strokeColor="@color/card_stroke" app:strokeWidth="1dp"
                    app:cornerRadius="14dp" app:backgroundTint="@color/card_bg"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="МОИ ТАРИФЫ" android:textSize="10sp" android:letterSpacing="0.12"
                android:textColor="#55FFFFFF"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="22dp" android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tv_no_tariffs"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Тарифов нет.\nНажмите «+» чтобы создать первый."
                android:textSize="14sp" android:textColor="#55FFFFFF" android:gravity="center"
                android:paddingVertical="32dp" android:paddingHorizontal="24dp"
                android:visibility="gone"/>

            <LinearLayout android:id="@+id/tariff_container"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingHorizontal="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_tariff"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="10dp"
                android:text="+ Добавить тариф" android:textSize="14sp" android:textColor="#AAFFFFFF"
                app:strokeColor="@color/card_stroke" app:strokeWidth="1dp"
                app:cornerRadius="16dp" app:backgroundTint="@color/card_bg"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Удерживайте тариф для редактирования"
                android:textSize="11sp" android:textColor="#38FFFFFF"
                android:layout_gravity="center_horizontal" android:layout_marginTop="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="28dp"
                android:text="▶   СТАРТ" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent_green" app:cornerRadius="20dp" app:elevation="0dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ══ RUNNING ════════════════════════════════════════════════════════════ -->
    <ScrollView android:id="@+id/screen_running"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:overScrollMode="never" android:fillViewport="true"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="36dp">

            <!-- Running header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="20dp" android:paddingTop="52dp" android:paddingBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tv_run_tariff"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Тариф" android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/white"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Поездка идёт" android:textSize="13sp" android:textColor="#77FFFFFF"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_gps_badge"
                    android:paddingHorizontal="12dp" android:paddingVertical="8dp">
                    <View android:id="@+id/gps_dot" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/dot_green" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GPS" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/accent_green"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Big distance + price card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp" android:layout_marginTop="10dp" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="24dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ПРОЙДЕНО" android:textSize="10sp" android:letterSpacing="0.12"
                        android:textColor="#55FFFFFF" android:layout_marginBottom="4dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="bottom">
                        <TextView android:id="@+id/tv_run_dist"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="64sp" android:textStyle="bold"
                            android:textColor="@color/white" android:letterSpacing="-0.03"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" км" android:textSize="22sp" android:textColor="#55FFFFFF"
                            android:paddingBottom="10dp"/>
                    </LinearLayout>
                    <View android:layout_width="80dp" android:layout_height="1dp"
                        android:background="#20FFFFFF" android:layout_marginVertical="14dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="СТОИМОСТЬ" android:textSize="10sp" android:letterSpacing="0.12"
                        android:textColor="#55FFFFFF" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_run_price"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ₽" android:textSize="42sp" android:textStyle="bold"
                        android:textColor="@color/accent_blue"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingHorizontal="16dp" android:layout_marginBottom="20dp">
                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:id="@+id/tv_run_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="00:00" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Время" android:textSize="10sp" android:textColor="#50FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginHorizontal="3dp"
                    app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:id="@+id/tv_run_fuel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00 л" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Топливо" android:textSize="10sp" android:textColor="#50FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:id="@+id/tv_run_speed"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 км/ч" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ср. скорость" android:textSize="10sp" android:textColor="#50FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:text="■   СТОП" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent_red" app:cornerRadius="20dp" app:elevation="0dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ══ RESULT ═════════════════════════════════════════════════════════════ -->
    <ScrollView android:id="@+id/screen_result"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:overScrollMode="never" android:fillViewport="true"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="36dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp" android:paddingTop="52dp" android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Итог поездки" android:textSize="28sp" android:textStyle="bold"
                    android:textColor="@color/white" android:letterSpacing="-0.02"/>
                <TextView android:id="@+id/tv_res_tariff"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="#77FFFFFF"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp" android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="28dp" android:gravity="center">

                    <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                        android:background="@drawable/circle_green" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✓" android:textSize="26sp" android:textColor="@color/accent_green"
                            android:layout_gravity="center"/>
                    </FrameLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="К ОПЛАТЕ" android:textSize="10sp" android:letterSpacing="0.12"
                        android:textColor="#66FFFFFF" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tv_res_price"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ₽" android:textSize="58sp" android:textStyle="bold"
                        android:textColor="@color/white" android:letterSpacing="-0.03"
                        android:layout_marginBottom="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#20FFFFFF" android:layout_marginBottom="20dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_res_dist"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.00 км" android:textSize="16sp" android:textStyle="bold" android:textColor="#DDFFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Расстояние" android:textSize="11sp" android:textColor="#55FFFFFF"/>
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="36dp"
                            android:background="#20FFFFFF" android:layout_gravity="center_vertical"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_res_time"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="00:00" android:textSize="16sp" android:textStyle="bold" android:textColor="#DDFFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Время" android:textSize="11sp" android:textColor="#55FFFFFF"/>
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="36dp"
                            android:background="#20FFFFFF" android:layout_gravity="center_vertical"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_res_fuel"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.00 л" android:textSize="16sp" android:textStyle="bold" android:textColor="#DDFFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Топливо" android:textSize="11sp" android:textColor="#55FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_trip"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:text="+ Новая поездка" android:textSize="15sp" android:textColor="#BBFFFFFF"
                app:strokeColor="@color/card_stroke" app:strokeWidth="1dp"
                app:cornerRadius="18dp" app:backgroundTint="@color/card_bg"/>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
